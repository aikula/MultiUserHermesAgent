# =============================================================================
# Hermes Agent — Environment Template
# =============================================================================
# Скопируйте в .env.hermes и заполните реальные значения:
#   cp .env.example .env.hermes
#   chmod 600 .env.hermes
#   nano .env.hermes
# =============================================================================

# ---- Образ ----
HERMES_IMAGE=nousresearch/hermes-agent:latest

# ---- OpenAI-совместимый API сервер ----
# Ключ: openssl rand -base64 32
API_SERVER_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32
API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
API_SERVER_CORS_ORIGINS=https://your-host.example

# ---- UID/GID контейнера (0 = root, лучше 1000:1000) ----
HERMES_UID=1000
HERMES_GID=1000

# ---- Прокси (для Telegram из РФ) ----
# Формат: http://user:password@host:port
# Если прокси не нужен — оставьте пустым
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,0.0.0.0

# ---- Traefik ----
HERMES_HOST=hermes.example.com
HERMES_DASHBOARD_PORT=9119
TRAEFIK_ENTRYPOINTS=websecure
TRAEFIK_CERTRESOLVER=letsencrypt

# ---- Basic auth для дашборда ----
# Генерация: htpasswd -nB <username>  (вывод вида: user:$apr1$...$...)
DASHBOARD_BASIC_AUTH_USER=admin
DASHBOARD_BASIC_AUTH_HASH=CHANGE_ME_htpasswd_apr1_hash

# ---- Gateway health endpoint (внутренний docker URL) ----
GATEWAY_HEALTH_URL=http://hermes-gateway:8642/health/detailed

# ---- LLM провайдер (зеркалит ~/.hermes/config.yaml) ----
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v4-flash
