# =============================================================================
# Hermes Agent — Environment Template
# =============================================================================
# Скопируйте в .env.hermes и заполните реальные значения:
#   cp .env.example .env.hermes
#   chmod 600 .env.hermes
#   nano .env.hermes
# =============================================================================

# ---- Образ ----
HERMES_IMAGE=nousresearch/hermes-agent:latest

# ---- OpenAI-совместимый API сервер ----
# Ключ: openssl rand -base64 32
API_SERVER_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32
API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
API_SERVER_CORS_ORIGINS=https://your-host.example

# ---- UID/GID контейнера (0 = root, лучше 1000:1000) ----
HERMES_UID=1000
HERMES_GID=1000

# ---- Прокси (для Telegram из РФ) ----
# Формат: http://user:password@host:port
# Если прокси не нужен — оставьте пустым
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,0.0.0.0

# ---- Traefik ----
HERMES_HOST=hermes.example.com
HERMES_DASHBOARD_PORT=9119
TRAEFIK_ENTRYPOINTS=websecure
TRAEFIK_CERTRESOLVER=letsencrypt

# ---- Basic auth для дашборда ----
# Генерация: htpasswd -nB <username>  (вывод вида: user:$apr1$...$...)
# Хэш хранится ИНЛАЙНОМ в docker-compose.yml с экранированием $$.
# В .env экранирование $$ НЕ работает, поэтому хэш туда не кладём.
# Здесь только логин:
DASHBOARD_BASIC_AUTH_USER=admin

# ---- Gateway health endpoint (внутренний docker URL) ----
GATEWAY_HEALTH_URL=http://hermes-gateway:8642/health/detailed

# ---- LLM провайдер (зеркалит ~/.hermes/config.yaml) ----
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v4-flash

# =============================================================================
# hermes-webapp (multi-user, FastAPI) — Фаза 1
# =============================================================================
# Роутинг: веб-интерфейс висит на https://${HERMES_HOST}/chat/*
# (Traefik: PathPrefix /chat + stripPrefix, см. docker-compose.yml)
# Дополнительных доменов не требуется.

# JWT secret для сессионных cookies (НЕ пусто в проде!)
# Генерация: openssl rand -hex 32
WEBAPP_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# Welcome-квота при регистрации (токенов, по умолчанию 2 000 000)
WELCOME_QUOTA=2000000

# Сколько последних сообщений из истории подмешивать в запрос к Hermes
# Меньше = меньше токенов на вызов. 8 = ~800 tok экономии против 20.
MAX_HISTORY_MESSAGES=8

# Суммаризатор памяти: после скольких новых сообщений в chat_history запускать
# LLM-синтез users/<uid>/memory.md. Меньше = чаще, но память компактнее.
SUMMARY_THRESHOLD=10

# Сколько последних сообщений подавать суммаризатору за раз (защита от раздувания)
SUMMARY_MAX_HISTORY=100

# Alert админу при превышении N% квоты (по умолчанию 80)
ALERT_THRESHOLD_PCT=80

# Telegram admin chat_id для алертов о превышении квоты (если задан — alert шлётся в TG)
TELEGRAM_ADMIN_CHAT_ID=

# Telegram admin bot token — отдельный бот для admin-уведомлений (если отличается от TELEGRAM_BOT_TOKEN)
# Если пуст — алерты шлются через TELEGRAM_BOT_TOKEN (тот же бот, что и relay)
TELEGRAM_ADMIN_BOT_TOKEN=

# Bootstrap invite-code (создаётся при старте webapp, если не существует).
# Используйте ОДИН РАЗ для первого админа, потом удалите из .env.hermes.
# Формат: 6+ символов, рекомендуется слово + число, например: pioneer-2026
INVITE_CODE_BOOTSTRAP=

# =============================================================================
# Telegram relay (Фаза 3) — встроен в hermes-webapp
# =============================================================================
# Токен бота от @BotFather. Если пусто — relay не запускается.
TELEGRAM_BOT_TOKEN=

# TTL link-code для привязки Telegram (секунды, по умолчанию 600 = 10 мин)
TELEGRAM_LINK_TTL=600

# Shared secret для внутренних вызовов relay → webapp (X-Internal-Secret header).
# Генерация: openssl rand -hex 32
WEBAPP_INTERNAL_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# =============================================================================
# User secret encryption (P0-4)
# =============================================================================
# Ключ для шифрования пользовательских секретов (email паролей).
# Если не задан — используется WEBAPP_INTERNAL_SECRET → JWT_SECRET.
# Генерация: openssl rand -hex 32
# USER_SECRET_ENCRYPTION_KEY=

# =============================================================================
# Cookie security (P1-6)
# =============================================================================
# Для production: COOKIE_SECURE=true, COOKIE_SAMESITE=lax
# Для локальной разработки (HTTP): COOKIE_SECURE=false
# COOKIE_SECURE=true
# COOKIE_SAMESITE=lax

# =============================================================================
# Hard quota reserve (P0-3)
# =============================================================================
# Минимальный резерв квоты для одного запроса (токенов)
# MIN_QUOTA_RESERVE_TOKENS=2048
# Максимум токенов на один ответ
# MAX_TOKENS_PER_RESPONSE=1024

# =============================================================================
# Speech-to-Text (STT) — GigaAM Voice API (для голосовых сообщений Telegram)
# =============================================================================
# URL OpenAI-совместимого STT API (GigaAM, русская речь)
# STT_API_URL=https://tts.kulinich.ai/v1/audio/transcriptions
# API ключ (Bearer token)
# STT_API_KEY=
